    {
      "name": "Create order",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Validate that Authorization header is set",
              "if (!pm.request.headers.has('Authorization')) {",
              "    console.error('Authorization header is missing!');",
              "}",
              "",
              "// Validate Authorization token variable is set",
              "const authToken = pm.environment.get('apiToken') || pm.collectionVariables.get('apiToken') || pm.globals.get('apiToken');",
              "if (!authToken) {",
              "    console.error('apiToken variable is not set in environment, collection, or globals!');",
              "}",
              "",
              "// Validate request body before sending",
              "try {",
              "    const requestBody = JSON.parse(pm.request.body.raw);",
              "    ",
              "    // Validate toolId",
              "    if (!requestBody.hasOwnProperty('toolId')) {",
              "        console.error('Request body is missing required field: toolId');",
              "    } else if (typeof requestBody.toolId !== 'number') {",
              "        console.error('toolId must be a number');",
              "    }",
              "    ",
              "    // Validate customerName",
              "    if (!requestBody.hasOwnProperty('customerName')) {",
              "        console.error('Request body is missing required field: customerName');",
              "    } else if (typeof requestBody.customerName !== 'string' || requestBody.customerName.trim() === '') {",
              "        console.error('customerName must be a non-empty string');",
              "    }",
              "    ",
              "    console.log('Request body validation passed');",
              "} catch (e) {",
              "    console.error('Request body is not valid JSON:', e.message);",
              "}",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test for successful response",
              "pm.test(\"Status code is 201 Created\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// Test for authorization errors",
              "pm.test(\"Authorization header is accepted\", function () {",
              "    pm.expect(pm.response.code).to.not.equal(401);",
              "    pm.expect(pm.response.code).to.not.equal(403);",
              "});",
              "",
              "// Test response structure for successful requests",
              "if (pm.response.code === 201) {",
              "    pm.test(\"Response has required fields\", function () {",
              "        var jsonData = pm.response.json();",
              "        pm.expect(jsonData).to.have.property('orderId');",
              "        pm.expect(jsonData).to.have.property('created');",
              "    });",
              "    ",
              "    pm.test(\"Order ID is valid\", function () {",
              "        var jsonData = pm.response.json();",
              "        pm.expect(jsonData.orderId).to.be.a('string');",
              "        pm.expect(jsonData.orderId).to.not.be.empty;",
              "    });",
              "}",
              "",
              "// Test for bad request errors",
              "pm.test(\"Request body validation\", function () {",
              "    if (pm.response.code === 400) {",
              "        var jsonData = pm.response.json();",
              "        pm.expect(jsonData).to.have.property('error');",
              "        console.log(\"Validation error:\", jsonData.error);",
              "    }",
              "});",
              "",
              "// Test for missing authorization",
              "pm.test(\"No missing authorization error\", function () {",
              "    var jsonData = pm.response.json();",
              "    if (pm.response.code === 401) {",
              "        pm.expect(jsonData.error).to.not.include(\"Missing Authorization header\");",
              "    }",
              "});",
              "",
              "// Test response time",
              "pm.test(\"Response time is acceptable\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});",
              "",
              "// Test content type",
              "pm.test(\"Content-Type is application/json\", function () {",
              "    pm.response.to.have.header(\"Content-Type\");",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "// Validate request body was properly formatted",
              "pm.test(\"Request body is valid JSON\", function () {",
              "    try {",
              "        var requestBody = JSON.parse(pm.request.body.raw);",
              "        pm.expect(requestBody).to.have.property('toolId');",
              "        pm.expect(requestBody).to.have.property('customerName');",
              "        pm.expect(requestBody.toolId).to.be.a('number');",
              "        pm.expect(requestBody.customerName).to.be.a('string');",
              "    } catch (e) {",
              "        pm.expect.fail(\"Request body is not valid JSON\");",
              "    }",
              "});",
              "",
              "console.log (pm.collectionVariables.get(\"apiToken\"));",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
